<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    android:background="@drawable/bg_photo_post_card"
    android:clickable="true"
    android:elevation="2dp"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:orientation="vertical"
    android:padding="16dp">

    <ImageView
        android:id="@+id/ivPhotoMetadataMedia"
        android:layout_width="match_parent"
        android:layout_height="148dp"
        android:adjustViewBounds="true"
        android:contentDescription="@string/travelshare_post_image_content_description"
        android:scaleType="centerCrop" />

    <TextView
        android:id="@+id/tvPhotoMetadataTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:textColor="#0F172A"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPhotoMetadataLocation"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="#2563EB"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvPhotoMetadataDate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textColor="#64748B"
        android:textSize="13sp" />

    <TextView
        android:id="@+id/tvPhotoMetadataDescription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:lineSpacingExtra="2dp"
        android:maxLines="3"
        android:textColor="#334155"
        android:textSize="15sp" />

    <TextView
        android:id="@+id/tvPhotoMetadataInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:textColor="#475569"
        android:textSize="13sp"
        android:textStyle="bold" />

</LinearLayout>
