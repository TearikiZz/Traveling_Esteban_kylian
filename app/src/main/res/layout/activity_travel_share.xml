<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F6F8"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/tvTravelShareTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/travelshare_screen_title"
        android:textColor="#1E293B"
        android:textSize="28sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTravelShareSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:layout_marginBottom="16dp"
        android:text="@string/travelshare_screen_subtitle"
        android:textColor="#475569"
        android:textSize="14sp" />

    <EditText
        android:id="@+id/etSearchPhotoMetadata"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_search_bar"
        android:hint="@string/travelshare_search_hint"
        android:imeOptions="actionDone"
        android:inputType="text"
        android:minHeight="48dp"
        android:padding="12dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvPhotoMetadata"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />

</LinearLayout>
